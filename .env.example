# ── Mode Selection ─────────────────────────────────────────────────────────────
# If DATABASE_PATH is set, server runs in database mode (multi-backend with web UI)
# If not set, server runs in legacy mode (single backend from S3_* env vars)

# Database mode (simpler option - just set the path):
DATABASE_PATH=./data.db

# Or use full connection string (takes precedence over DATABASE_PATH):
# DATABASE_URL=file:./data.db?cache=shared&_fk=1

# JWT secret for API authentication (required in database mode)
JWT_SECRET=your-secret-key-change-me

# ── S3 / Storage (Legacy mode only) ────────────────────────────────────────────
S3_BUCKET=my-webdav-bucket
S3_REGION=us-east-1

# Optional: custom endpoint for MinIO, Cloudflare R2, etc.
# S3_ENDPOINT=http://localhost:9000

# Optional: force path-style URLs (required for MinIO)
# S3_FORCE_PATH_STYLE=true

# Optional: explicit credentials (defaults to AWS credential chain)
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_SESSION_TOKEN=

# Optional: prefix all stored keys under this path
# S3_KEY_PREFIX=webdav/

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Authentication (Legacy mode only) ──────────────────────────────────────────
# AUTH_MODE: "local" or "api"
AUTH_MODE=local

# Local auth (AUTH_MODE=local)
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=changeme

# API auth (AUTH_MODE=api)
# POST {username, password} → expects 200 + {user_id, username}
# AUTH_API_URL=http://your-auth-service/auth

# ── Security ──────────────────────────────────────────────────────────────────
# Max upload size in bytes (default 100MB)
# MAX_FILE_SIZE_BYTES=104857600

# Requests per minute per IP (default 100)
# RATE_LIMIT_PER_MINUTE=100

# Comma-separated allowed file extensions (empty = all allowed)
# ALLOWED_EXTENSIONS=.txt,.pdf,.docx,.xlsx,.jpg,.jpeg,.png,.zip,.csv

# Mount the filesystem read-only (GET/PROPFIND only)
# READ_ONLY=false